# Copy this file to terraform.tfvars and fill in real values.
# Never commit terraform.tfvars to source control — add it to .gitignore.

aws_region  = "us-east-1"
project     = "securecart"
bucket_name = "securecart-unique-bucket-name-24032026"

# Paste your SSH public key contents here (cat ~/.ssh/id_rsa.pub)
bastion_public_key = "ssh-rsa AAAA... your-bastion-key"
app_public_key     = "ssh-rsa AAAA... your-app-key"

# db_password is sensitive — prefer passing via environment variable:
#   export TF_VAR_db_password="YourStrongPassword"
# or use AWS Secrets Manager and remove this variable entirely.
db_password = "CHANGE_ME_use_secrets_manager"
