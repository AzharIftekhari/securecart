# ─────────────────────────────────────────────
# Terraform State & Lock Files
# Contains real infrastructure IDs, IPs, secrets
# ─────────────────────────────────────────────
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform.tfstate.lock.info

# ─────────────────────────────────────────────
# Terraform Working Directory
# Downloaded providers & modules (large binaries)
# ─────────────────────────────────────────────
.terraform/
.terraform.lock.hcl

# ─────────────────────────────────────────────
# Variable Files Containing Secrets
# db_password and other sensitive values live here
# ─────────────────────────────────────────────
*.tfvars
*.tfvars.json

# ─────────────────────────────────────────────
# SSH Private Keys generated by Terraform
# These are written locally by the compute module
# ─────────────────────────────────────────────
*.pem
*.key
*.ppk
# ─────────────────────────────────────────────
# Terraform Plan Output
# Can contain secrets in plaintext
# ─────────────────────────────────────────────
tfplan
*.tfplan

# ─────────────────────────────────────────────
# Crash & Debug Logs
# ─────────────────────────────────────────────
crash.log
crash.*.log
*.log

# ─────────────────────────────────────────────
# OS & Editor Junk
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

keys.tf
