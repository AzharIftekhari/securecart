# ─────────────────────────────────────────────
# SECRETS & CREDENTIALS  ← most critical
# ─────────────────────────────────────────────

# Terraform variable files that may contain passwords, keys, tokens
*.tfvars
*.tfvars.json

# Keep the example tfvars (no real values) — remove this line if yours has real values
!terraform.tfvars.example

# SSH Private Keys generated by the compute module
*.pem
*.key
*-key.pem
securecart-bastion-*.pem
securecart-app-*.pem

# AWS credentials / config if accidentally placed in project folder
.aws/
credentials
aws-credentials*

# ─────────────────────────────────────────────
# TERRAFORM STATE  ← contains all resource details + secrets in plaintext
# ─────────────────────────────────────────────
*.tfstate
*.tfstate.*
*.tfstate.backup

# State lock file
.terraform.tfstate.lock.info

# ─────────────────────────────────────────────
# TERRAFORM WORKING DIRECTORY
# ─────────────────────────────────────────────

# Downloaded providers and modules (large binaries, not needed in git)
.terraform/
.terraform.lock.hcl     # Optional: some teams commit this for provider version pinning
                        # If you want to pin providers, remove this line

# Plan output files (can contain sensitive values in plaintext)
*.tfplan
tfplan
*.plan

# Crash and log files
crash.log
crash.*.log
*.tflog

# ─────────────────────────────────────────────
# OS & EDITOR JUNK
# ─────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# VS Code
.vscode/
*.code-workspace

# JetBrains (IntelliJ, GoLand, etc.)
.idea/
*.iml

# Vim / Emacs swap files
*.swp
*.swo
*~
\#*\#

# ─────────────────────────────────────────────
# OVERRIDE FILES  ← local-only Terraform customisations
# ─────────────────────────────────────────────
override.tf
override.tf.json
*_override.tf
*_override.tf.json

secrets
